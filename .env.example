# ============================================================
# COD Command Center — Environment Variables Example
# Copy this file to .env.local and fill in your real values
# ============================================================

# --- Supabase (REQUIRED) ---
# Find all values at: https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Your Supabase anon/public key (use one of the following):
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   ← new Supabase naming (also supported)

# Your Supabase service role secret key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SECRET_KEY=                    ← new Supabase naming (also supported)

# --- Telegram Notifications (OPTIONAL) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
